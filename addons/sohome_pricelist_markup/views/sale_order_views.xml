<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_sohome_markup_over" model="ir.ui.view">
        <field name="name">sale.order.form.sohome.markup.over</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_order_template_id']" position="after">
                <group>
                    <field name="x_sohome_markup" groups="sohome_pricelist_markup.group_sohome_sale_markup"/>
                    <field name="x_sohome_over_percent" groups="sohome_pricelist_markup.group_sohome_sale_over"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
